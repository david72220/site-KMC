---
/* ============================================
   PAGE – HABILITATIONS ÉLECTRIQUES
   Static page for electrical safety certifications.
   ============================================ */

import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

const pageTitle = 'Habilitations électriques';
const pageDescription = 'Obtenez vos habilitations électriques B0-H0, B1V1-B2V2 et renouvellement chez KMC à Abidjan. Formations pratiques et certifiantes pour la sécurité en milieu électrique et fibre optique.';
const pageImage = 'https://kmc.ci/images/og-habilitations.jpg';

// ── Habilitation data ──
const habilitations = [
  {
    id: 'b0-h0',
    title: 'Habilitation B0-H0',
    subtitle: 'Non-électricien — accès interdit aux ouvrages',
    description:
      'Formation destinée au personnel non-électricien intervenant à proximité d\'installations électriques. Apprenez à reconnaître les dangers, appliquer les consignes de sécurité et utiliser l\'EPI adapté. Obligatoire pour tout opérateur en génie civil et pose de câbles.',
    duree: '1 jour',
    prix: 75_000,
    color: '#F97316', // orange
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m0-3.75a6 6 0 0 1 6 6v.008a6 6 0 0 1-6 6v.008a6 6 0 0 1-6-6v-.008a6 6 0 0 1 6-6Zm0 0V5.25m0 13.5V19.5m0-15L4.5 9m15 0L19.5 9" /></svg>`,
  },
  {
    id: 'b1v1-b2v2',
    title: 'Habilitation B1V1 — B2V2',
    subtitle: 'Électricien — travaux sous tension',
    description:
      'Formation pour électriciens et techniciens devant effectuer des opérations d\'ordre électrique sur des ouvrages alimentés en BT. Maîtrisez les procédures de consignation, les distances d\'approche et l\'utilisation des équipements de protection collective et individuelle.',
    duree: '2 jours',
    prix: 125_000,
    color: '#2dd4bf', // cyan
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-10.5 10.5 10.5m-14 0 4.5 10.5 4.5-10.5m-13.5 0h18" /></svg>`,
  },
  {
    id: 'renouvellement',
    title: 'Renouvellement habilitation',
    subtitle: 'Recyclage et mise à jour annuelle',
    description:
      'Session de recyclage obligatoire pour le renouvellement de votre habilitation électrique. Révision des évolutions réglementaires, retour d\'expérience sur accidents et mise à jour des gestes professionnels. Nécessaire tous les 12 mois.',
    duree: '1/2 journée',
    prix: 45_000,
    color: '#eab308', // ochre/gold
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182" /></svg>`,
  },
];

// JSON-LD: Course schema for each habilitation
const coursesJsonLd = habilitations.map((h) => ({
  '@context': 'https://schema.org',
  '@type': 'Course',
  name: h.title,
  description: h.description,
  provider: {
    '@type': 'EducationalOrganization',
    name: 'KMC - Knowledge Management Center',
    url: 'https://kmc.ci',
  },
  timeRequired: h.duree,
  offers: {
    '@type': 'Offer',
    price: h.prix.toString(),
    priceCurrency: 'XOF',
    availability: 'https://schema.org/InStock',
  },
}));

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'EducationalOrganization',
      name: 'KMC - Knowledge Management Center',
      url: 'https://kmc.ci',
      logo: 'https://kmc.ci/images/logo-kmc.png',
    },
    ...coursesJsonLd,
  ],
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  image={pageImage}
  type="website"
  jsonLd={jsonLd}
>
  <Navigation />

  {/* ── Page Hero ── */}
  <section class="relative bg-[#070a10] pt-32 pb-20 md:pt-40 md:pb-28 overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_rgba(249,115,22,0.06)_0%,_transparent_60%)]"></div>
    <div class="max-w-7xl mx-auto px-6 lg:px-8 relative">
      <div class="max-w-3xl">
        <p class="text-[#F97316] text-sm font-semibold tracking-widest uppercase mb-4">
          Sécurité électrique
        </p>
        <h1 class="font-display text-4xl md:text-6xl font-bold text-[#f5f5f0] mb-6 leading-tight">
          Habilitations <span class="text-[#eab308]">B0-H0</span> & <span class="text-[#2dd4bf]">B1V1-B2V2</span>
        </h1>
        <p class="text-[#a1a1aa] text-lg md:text-xl leading-relaxed max-w-2xl">
          Formez votre personnel aux habilitations électriques obligatoires pour intervenir en toute sécurité sur les réseaux fibre et installations photovoltaïques en Côte d'Ivoire.
        </p>
      </div>
    </div>
  </section>

  {/* ── Habilitations Grid ── */}
  <section class="relative bg-[#070a10] pb-24 md:pb-32">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8" id="habilitations-grid">
        {habilitations.map((h, idx) => (
          <article
            class="habilitation-card group relative rounded-2xl border border-white/[0.08] bg-gradient-to-br from-white/[0.04] to-transparent backdrop-blur-sm p-8 hover:border-opacity-40 transition-all duration-500 hover:-translate-y-2"
            style={`border-color: rgba(255,255,255,0.08); --card-accent: ${h.color};`}
          >
            <div
              class="absolute top-0 right-0 w-32 h-32 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2 opacity-5 group-hover:opacity-10 transition-opacity"
              style={`background-color: ${h.color};`}
            ></div>

            <div class="relative">
              {/* Icon */}
              <div
                class="w-14 h-14 rounded-xl flex items-center justify-center mb-6"
                style={`background-color: ${h.color}15; color: ${h.color};`}
                set:html={h.icon}
              />

              <p class="text-[#a1a1aa] text-xs font-semibold tracking-wider uppercase mb-2">
                {h.subtitle}
              </p>
              <h2 class="font-display text-2xl font-bold text-[#f5f5f0] mb-4">
                {h.title}
              </h2>
              <p class="text-[#a1a1aa] text-sm leading-relaxed mb-6">
                {h.description}
              </p>

              {/* Meta row */}
              <div class="flex items-center gap-4 mb-6 text-sm">
                <span class="inline-flex items-center text-[#a1a1aa]">
                  <svg class="w-4 h-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                  </svg>
                  {h.duree}
                </span>
              </div>

              <div class="flex items-center justify-between">
                <span class="text-[#eab308] font-semibold text-xl">
                  {h.prix.toLocaleString('fr-FR')} FCFA
                </span>
                <a
                  href="/contact/"
                  class="inline-flex items-center rounded-full px-5 py-2.5 text-sm font-semibold transition-colors duration-300"
                  style={`background-color: ${h.color}20; color: ${h.color};`}
                >
                  S'inscrire
                  <svg class="ml-2 w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>

      {/* Info box */}
      <div class="mt-16 rounded-2xl border border-white/[0.08] bg-gradient-to-br from-white/[0.04] to-transparent backdrop-blur-sm p-8 md:p-10">
        <div class="flex flex-col md:flex-row md:items-center gap-6">
          <div class="flex-1">
            <h3 class="font-display text-xl font-bold text-[#f5f5f0] mb-2">
              Pourquoi l'habilitation électrique est obligatoire ?
            </h3>
            <p class="text-[#a1a1aa] leading-relaxed">
              Toute intervention sur les réseaux fibre optique en aérien ou en infrastructure électrique partagée nécessite une habilitation conforme au <strong class="text-[#f5f5f0]">NF C 18-510</strong>. KMC délivre les certificats reconnus par les opérateurs Orange, MTN et Moov Africa.
            </p>
          </div>
          <a
            href="/contact/"
            class="inline-flex items-center justify-center rounded-full bg-[#f5f5f0] px-6 py-3 text-[#070a10] font-display font-bold hover:bg-[#eab308] transition-colors duration-300 shrink-0"
          >
            Demander un devis groupe
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  /* ── IntersectionObserver reveal for cards ── */
  document.addEventListener('DOMContentLoaded', () => {
    const cards = document.querySelectorAll('.habilitation-card');
    if (!cards.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            el.style.opacity = '1';
            el.style.transform = 'translateY(0)';
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
    );

    cards.forEach((card, i) => {
      const el = card as HTMLElement;
      el.style.opacity = '0';
      el.style.transform = 'translateY(40px)';
      el.style.transition = `opacity 0.7s ease ${i * 0.1}s, transform 0.7s ease ${i * 0.1}s`;
      observer.observe(card);
    });
  });
</script>