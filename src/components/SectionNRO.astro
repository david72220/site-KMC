---
/**
 * Section NRO — Nœud de Raccordement Optique
 * Scrollytelling step 3: the central distribution hub where fiber converges.
 */
---

<section
  id="nro"
  class="nro-section relative w-full min-h-screen flex items-center justify-center bg-kmc-night overflow-hidden"
  aria-label="Nœud de Raccordement Optique"
>
  <div class="nro-container relative w-full max-w-7xl mx-auto px-6 py-24 md:py-0">
    <!-- Background glow -->
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
      <div class="nro-glow w-[500px] h-[500px] rounded-full bg-kmc-cyan/10 blur-[100px]"></div>
    </div>

    <div class="relative grid md:grid-cols-2 gap-12 items-center">
      <!-- Left: Visual representation of NRO hub -->
      <div class="nro-visual relative order-2 md:order-1">
        <div class="relative w-full aspect-square max-w-[420px] mx-auto">
          <!-- Central node -->
          <div class="nro-center absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-24 h-24 rounded-full bg-kmc-cyan/20 border-2 border-kmc-cyan flex items-center justify-center z-10">
            <span class="text-kmc-cyan font-display font-bold text-lg">NRO</span>
          </div>

          <!-- Orbital rings -->
          <div class="nro-ring-1 absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-40 h-40 rounded-full border border-kmc-cyan/30"></div>
          <div class="nro-ring-2 absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-56 h-56 rounded-full border border-kmc-cyan/20"></div>
          <div class="nro-ring-3 absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-72 h-72 rounded-full border border-kmc-cyan/10"></div>

          <!-- Satellite nodes (operators feeding into NRO) -->
          <div class="nro-satellite absolute top-[15%] left-[15%] w-10 h-10 rounded-full bg-op-orange/80 flex items-center justify-center text-xs font-bold text-white">O</div>
          <div class="nro-satellite absolute top-[10%] right-[25%] w-10 h-10 rounded-full bg-op-yellow/80 flex items-center justify-center text-xs font-bold text-white">M</div>
          <div class="nro-satellite absolute bottom-[20%] right-[15%] w-10 h-10 rounded-full bg-op-blue/80 flex items-center justify-center text-xs font-bold text-white">B</div>

          <!-- Connection lines to center -->
          <svg class="absolute inset-0 w-full h-full" viewBox="0 0 420 420">
            <line class="nro-line" x1="63" y1="63" x2="210" y2="210" stroke="#2DD4BF" stroke-width="1.5" opacity="0.6" />
            <line class="nro-line" x1="315" y1="42" x2="210" y2="210" stroke="#2DD4BF" stroke-width="1.5" opacity="0.6" />
            <line class="nro-line" x1="357" y1="336" x2="210" y2="210" stroke="#2DD4BF" stroke-width="1.5" opacity="0.6" />
          </svg>
        </div>
      </div>

      <!-- Right: Content -->
      <div class="nro-content order-1 md:order-2 text-center md:text-left">
        <span class="inline-block text-kmc-cyan font-display text-sm tracking-widest uppercase mb-4">Étape 3</span>
        <h2 class="nro-title font-display text-4xl md:text-5xl lg:text-6xl font-bold text-kmc-white mb-6 leading-tight">
          Le Nœud de<br />
          <span class="text-kmc-cyan">Raccordement Optique</span>
        </h2>
        <p class="nro-desc text-lg text-kmc-light/80 leading-relaxed mb-8 max-w-xl mx-auto md:mx-0">
          C'est ici que converge la lumière de tous les opérateurs. Le <strong class="text-kmc-cyan">NRO</strong> distribue
          la fibre vers les quartiers et les immeubles. C'est le cœur battant du réseau FTTH,
          le point de passage obligé entre le backbone et le dernier kilomètre.
        </p>

        <div class="nro-stats grid grid-cols-3 gap-4 max-w-md mx-auto md:mx-0">
          <div class="text-center md:text-left">
            <div class="font-display text-2xl md:text-3xl font-bold text-kmc-cyan">1000+</div>
            <div class="text-xs text-kmc-light/60 uppercase tracking-wider"> fibres convergentes</div>
          </div>
          <div class="text-center md:text-left">
            <div class="font-display text-2xl md:text-3xl font-bold text-kmc-cyan">10 Gbps</div>
            <div class="text-xs text-kmc-light/60 uppercase tracking-wider">débit par lien</div>
          </div>
          <div class="text-center md:text-left">
            <div class="font-display text-2xl md:text-3xl font-bold text-kmc-cyan">{'<'}1ms</div>
            <div class="text-xs text-kmc-light/60 uppercase tracking-wider">latence interne</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  if (typeof window !== 'undefined' && !window.matchMedia('(pointer: coarse)').matches) {
    Promise.all([
      import('gsap'),
      import('gsap/ScrollTrigger'),
    ]).then(([{ gsap }, { ScrollTrigger }]) => {
      gsap.registerPlugin(ScrollTrigger);

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: '.nro-section',
          start: 'top top',
          end: '+=130%',
          pin: '.nro-container',
          scrub: 1,
        },
      });

      // Glow pulse
      tl.fromTo('.nro-glow', { scale: 0.5, opacity: 0 }, { scale: 1, opacity: 1, duration: 0.3 }, 0);

      // Rings expand from center
      tl.fromTo(
        '.nro-ring-1',
        { scale: 0, opacity: 0 },
        { scale: 1, opacity: 1, duration: 0.25, ease: 'back.out(1.7)' },
        0.1
      );
      tl.fromTo(
        '.nro-ring-2',
        { scale: 0, opacity: 0 },
        { scale: 1, opacity: 1, duration: 0.25, ease: 'back.out(1.7)' },
        0.2
      );
      tl.fromTo(
        '.nro-ring-3',
        { scale: 0, opacity: 0 },
        { scale: 1, opacity: 1, duration: 0.25, ease: 'back.out(1.7)' },
        0.3
      );

      // Satellites fly in
      tl.fromTo(
        '.nro-satellite',
        { scale: 0, opacity: 0 },
        { scale: 1, opacity: 1, duration: 0.2, stagger: 0.08, ease: 'back.out(2)' },
        0.35
      );

      // Lines draw in
      tl.fromTo(
        '.nro-line',
        { strokeDasharray: 300, strokeDashoffset: 300 },
        { strokeDashoffset: 0, duration: 0.3, stagger: 0.06, ease: 'power2.out' },
        0.5
      );

      // Content fade up
      tl.fromTo(
        '.nro-content > *',
        { y: 40, opacity: 0 },
        { y: 0, opacity: 1, duration: 0.25, stagger: 0.08, ease: 'power2.out' },
        0.4
      );
    });
  }
</script>