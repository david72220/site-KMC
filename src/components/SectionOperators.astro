---
interface Props {
    title?: string;
}
const { title = "Les 3 Opérateurs" } = Astro.props;
---

<section id="operators" class="operators-section relative min-h-screen w-full overflow-hidden bg-kmc-night">
    <div class="operators-container relative z-10 flex min-h-screen flex-col items-center justify-center px-6 py-20">
        <div class="text-center mb-16">
            <span class="inline-block px-4 py-1 rounded-full bg-kmc-cyan/10 text-kmc-cyan text-sm font-medium tracking-wider uppercase mb-4">Infrastructure</span>
            <h2 class="font-display text-4xl md:text-6xl font-bold text-white mb-4">{title}</h2>
            <p class="text-kmc-light/70 max-w-2xl mx-auto text-lg">La fibre optique en Côte d'Ivoire est déployée par trois acteurs majeurs qui construisent le réseau national.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl w-full">
            <!-- Operator 1: Orange -->
            <div class="operator-card group relative rounded-2xl border border-op-orange/20 bg-gradient-to-b from-op-orange/10 to-transparent p-8 text-center transition-all duration-500 hover:border-op-orange/50 hover:shadow-[0_0_40px_-10px_rgba(249,115,22,0.3)]">
                <div class="mx-auto mb-6 flex h-20 w-20 items-center justify-center rounded-full bg-op-orange/20">
                    <svg class="h-10 w-10 text-op-orange" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8.288 15.038a5.25 5.25 0 017.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0M12.53 18.22l-.53.53-.53-.53a.75.75 0 011.06 0z"/>
                    </svg>
                </div>
                <h3 class="font-display text-2xl font-bold text-op-orange mb-2">Opérateur Orange</h3>
                <p class="text-kmc-light/70 text-sm leading-relaxed">Leader historique des télécoms en Côte d'Ivoire. Déploiement FTTH massif dans les grandes agglomérations.</p>
                <div class="mt-6 h-1 w-12 bg-op-orange/40 mx-auto rounded-full group-hover:w-24 transition-all duration-500"></div>
            </div>

            <!-- Operator 2: MTN/Yellow -->
            <div class="operator-card group relative rounded-2xl border border-op-yellow/20 bg-gradient-to-b from-op-yellow/10 to-transparent p-8 text-center transition-all duration-500 hover:border-op-yellow/50 hover:shadow-[0_0_40px_-10px_rgba(234,179,8,0.3)]">
                <div class="mx-auto mb-6 flex h-20 w-20 items-center justify-center rounded-full bg-op-yellow/20">
                    <svg class="h-10 w-10 text-op-yellow" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418"/>
                    </svg>
                </div>
                <h3 class="font-display text-2xl font-bold text-op-yellow mb-2">Opérateur MTN</h3>
                <p class="text-kmc-light/70 text-sm leading-relaxed">Réseau mobile étendu avec déploiement fibre en parallèle. Forte présence dans les zones commerciales.</p>
                <div class="mt-6 h-1 w-12 bg-op-yellow/40 mx-auto rounded-full group-hover:w-24 transition-all duration-500"></div>
            </div>

            <!-- Operator 3: Moov/Blue -->
            <div class="operator-card group relative rounded-2xl border border-op-blue/20 bg-gradient-to-b from-op-blue/10 to-transparent p-8 text-center transition-all duration-500 hover:border-op-blue/50 hover:shadow-[0_0_40px_-10px_rgba(59,130,246,0.3)]">
                <div class="mx-auto mb-6 flex h-20 w-20 items-center justify-center rounded-full bg-op-blue/20">
                    <svg class="h-10 w-10 text-op-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/>
                    </svg>
                </div>
                <h3 class="font-display text-2xl font-bold text-op-blue mb-2">Opérateur Moov</h3>
                <p class="text-kmc-light/70 text-sm leading-relaxed">Filiale du groupe Maroc Telecom. Expansion rapide du réseau fibre, particulièrement dans l'intérieur du pays.</p>
                <div class="mt-6 h-1 w-12 bg-op-blue/40 mx-auto rounded-full group-hover:w-24 transition-all duration-500"></div>
            </div>
        </div>
    </div>
</section>

<script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    gsap.registerPlugin(ScrollTrigger);

    const isMobile = window.matchMedia('(pointer: coarse)').matches;

    // Pin on desktop only
    if (!isMobile) {
        ScrollTrigger.create({
            trigger: '.operators-section',
            start: 'top top',
            end: '+=120%',
            pin: '.operators-container',
            scrub: 1,
        });
    }

    // Animate cards staggered
    gsap.from('.operator-card', {
        scrollTrigger: {
            trigger: '.operators-section',
            start: 'top 80%',
            end: 'top 20%',
            scrub: 1,
        },
        y: 60,
        opacity: 0,
        stagger: 0.15,
        ease: 'power2.out',
    });

    // Scale title
    gsap.from('.operators-container h2', {
        scrollTrigger: {
            trigger: '.operators-section',
            start: 'top 80%',
            end: 'top 40%',
            scrub: 1,
        },
        scale: 0.9,
        opacity: 0,
        ease: 'power2.out',
    });
</script>