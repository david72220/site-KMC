---
/**
 * ImageSeparator — pleine largeur entre deux sections
 *
 * Usage :
 *   <ImageSeparator src="/images/chantier-fibre.jpg" alt="Technicien sur chantier" />
 *
 * Sans image (placeholder visible en dev) :
 *   <ImageSeparator label="Photo chantier fibre" />
 */

interface Props {
  src?: string;       // chemin dans public/images/
  alt?: string;
  label?: string;     // texte affiché quand src est absent
  height?: string;    // hauteur CSS, défaut 60vh
  overlay?: boolean;  // ajoute un dégradé sombre sur l'image
}

const {
  src,
  alt = '',
  label = 'Image à venir',
  height = '60vh',
  overlay = true,
} = Astro.props;
---

<div
  class="image-separator relative w-full overflow-hidden"
  style={`height: ${height};`}
>
  {src ? (
    <>
      <img
        src={src}
        alt={alt}
        class="separator-img absolute inset-0 w-full h-full object-cover"
        loading="lazy"
      />
      {overlay && (
        <div class="absolute inset-0 bg-gradient-to-b from-[#070a10]/60 via-transparent to-[#070a10]/60"></div>
      )}
    </>
  ) : (
    /* Placeholder visible jusqu'à ce que l'image soit disponible */
    <div class="absolute inset-0 flex flex-col items-center justify-center border-2 border-dashed border-[#2dd4bf]/30 bg-[#0d1829]">
      <svg class="w-12 h-12 text-[#2dd4bf]/40 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3 21h18a.75.75 0 00.75-.75V6A.75.75 0 0021 3H3a.75.75 0 00-.75.75v14.25c0 .414.336.75.75.75z" />
      </svg>
      <p class="text-[#2dd4bf]/60 text-sm font-mono">{label}</p>
      <p class="text-[#a1a1aa]/40 text-xs mt-1">Déposer dans public/images/ puis renseigner src=""</p>
    </div>
  )}
</div>

<style>
  /* Léger effet parallax au scroll via transform */
  .separator-img {
    will-change: transform;
    transform: scale(1.1);
    transition: transform 0.1s linear;
  }
</style>

<script>
  /* Parallax simple via IntersectionObserver + scroll */
  document.querySelectorAll<HTMLElement>('.image-separator').forEach((section) => {
    const img = section.querySelector<HTMLElement>('.separator-img');
    if (!img) return;

    const onScroll = () => {
      const rect = section.getBoundingClientRect();
      const ratio = rect.top / window.innerHeight;
      img.style.transform = `scale(1.1) translateY(${ratio * 30}px)`;
    };

    window.addEventListener('scroll', onScroll, { passive: true });
  });
</script>
