---
/**
 * ScrollytellingScene — Séquence en 3 temps :
 *   1. Image 1 (centre de formation) statique
 *   2. Texte + logos apparaissent en overlay sur Image 1
 *   3. Tout disparaît → vidéo animée réseau
 */
---

<section id="scrolly-scene" aria-label="Présentation KMC — Institut de Formation" style="height: 500vh;">
  <div id="scrolly-pin" class="sticky top-0 w-full overflow-hidden bg-[#0a1628]" style="height: 100vh;">

    <!-- COUCHE 1 (fond) — Vidéo réseau animée -->
    <div id="scrolly-video-wrap" class="absolute inset-0 z-10 will-change-transform">
      <video
        class="w-full h-full object-cover"
        autoplay
        loop
        muted
        playsinline
        preload="auto"
      >
        <source src="/images/video flux fibre.mp4" type="video/mp4" />
      </video>
    </div>

    <!-- COUCHE 2 — Image 1 : centre de formation -->
    <div id="scrolly-img1" class="absolute inset-0 z-20">
      <img
        src="/images/Image 1 - centre de formation.png"
        alt="KMC — Institut de formation fibre optique et photovoltaïque, Abidjan, Côte d'Ivoire"
        class="w-full h-full object-cover select-none"
        draggable="false"
        loading="eager"
        decoding="async"
      />
      <!-- Dégradé sombre en bas pour lisibilité du texte -->
      <div class="absolute inset-0 bg-gradient-to-t from-[#0a1628]/85 via-[#0a1628]/30 to-transparent"></div>
    </div>

    <!-- COUCHE 3 (avant-plan) — Texte + logos, par-dessus Image 1 -->
    <div
      id="scrolly-text"
      class="absolute inset-0 z-30 flex flex-col items-center justify-end pb-10 px-4 text-center"
      style="opacity: 0;"
    >
      <!-- Carte verre dépoli -->
      <div class="max-w-3xl w-full rounded-2xl border border-white/10 px-8 py-7"
           style="backdrop-filter: blur(14px); background: rgba(10,22,40,0.68);">

        <!-- Logo KMC -->
        <div class="flex justify-center mb-5">
          <div class="bg-white/95 rounded-xl px-5 py-2">
            <img
              src="/images/logo-kmc.png"
              alt="KMC — Knowledge Management Center"
              class="h-10 w-auto object-contain"
            />
          </div>
        </div>

        <!-- H1 — grand titre -->
        <h1 class="font-display text-5xl md:text-6xl lg:text-7xl font-bold text-white leading-tight mb-4">
          Institut Professionnel<br/>
          de Formation en&nbsp;<span class="text-[#1e9ad7]">Fibre Optique</span>
        </h1>

        <!-- H2 -->
        <h2 class="text-base md:text-xl text-white/80 font-light max-w-2xl mx-auto mb-4 leading-relaxed">
          Devenez technicien <span class="text-[#F59E0B] font-medium">reconnu par l'état Ivoirien</span>
          en fibre optique à Abidjan avec notre institut de formation certifié.
        </h2>

        <!-- Texte enrichi -->
        <p class="text-white/60 text-sm md:text-base max-w-xl mx-auto mb-6 leading-relaxed">
          KMC forme des professionnels aux métiers d'avenir : raccordement&nbsp;FTTH,
          supervision&nbsp;NRO, installation photovoltaïque.
          Nos programmes sont <span class="text-[#1e9ad7] font-medium">éligibles au financement&nbsp;FDFP</span>
          et reconnus par l'Agence Emploi Jeunes.
        </p>

        <!-- Séparateur + logos -->
        <div class="flex items-center justify-center gap-4 mb-5">
          <div class="h-px w-16 bg-[#1e9ad7]/30"></div>
          <span class="text-white/35 text-xs tracking-widest uppercase">Partenaires officiels</span>
          <div class="h-px w-16 bg-[#1e9ad7]/30"></div>
        </div>

        <div class="flex items-center justify-center gap-8 flex-wrap mb-6">
          <a
            href="https://fdfp.ci/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="FDFP — Fonds de Développement de la Formation Professionnelle"
            class="block bg-white/95 hover:bg-white rounded-xl px-4 py-2.5 transition-all duration-300 hover:scale-105 hover:shadow-[0_0_20px_rgba(30,154,215,0.4)]"
          >
            <img src="/images/FDFP.png" alt="FDFP" class="h-12 w-auto object-contain" loading="lazy" />
          </a>
          <a
            href="https://agenceemploijeunes.ci/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Agence Emploi Jeunes — Guichet Unique de l'Emploi en Côte d'Ivoire"
            class="block bg-white/95 hover:bg-white rounded-xl px-4 py-2.5 transition-all duration-300 hover:scale-105 hover:shadow-[0_0_20px_rgba(30,154,215,0.4)]"
          >
            <img src="/images/AEJ.png" alt="Agence Emploi Jeunes" class="h-12 w-auto object-contain" loading="lazy" />
          </a>
        </div>

        <!-- Label habilitation — en bas, gros, gras -->
        <div class="border-t border-white/10 pt-4">
          <p class="text-white font-bold text-base md:text-lg tracking-wide">
            Habilité par l'État Ivoirien &nbsp;·&nbsp; Abidjan, Côte d'Ivoire
          </p>
        </div>

      </div>
    </div>

  </div>
</section>

<script>
  import { gsap, ScrollTrigger, initLenis } from '../lib/scroll';

  initLenis();

  function initScrollytelling() {
    const img1 = document.getElementById('scrolly-img1');
    const textPanel = document.getElementById('scrolly-text');
    if (!img1 || !textPanel) return;

    const tl = gsap.timeline();

    // Phase 1 — Texte apparaît par-dessus Image 1 (progress 0 → 0.35)
    tl.to(textPanel, {
      opacity: 1,
      duration: 1,
      ease: 'power1.out',
    });

    // Phase 2 — Image 1 + texte disparaissent ensemble → vidéo (progress 0.45 → 0.75)
    tl.to([img1, textPanel], {
      opacity: 0,
      duration: 1,
      ease: 'power1.inOut',
    }, 1.4);

    // Phase 3 — Temps pour profiter de la vidéo
    tl.to({}, { duration: 0.6 });

    // Phase 4 — Zoom vers la gauche (opérateurs Orange, Moov, MTN)
    const videoWrap = document.getElementById('scrolly-video-wrap');
    if (videoWrap) {
      tl.to(videoWrap, {
        scale: 1.45,
        transformOrigin: 'left center',
        duration: 1,
        ease: 'power2.inOut',
      });
    }

    ScrollTrigger.create({
      trigger: '#scrolly-scene',
      start: 'top top',
      end: 'bottom bottom',
      scrub: 1.2,
      animation: tl,
      invalidateOnRefresh: true,
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initScrollytelling);
  } else {
    initScrollytelling();
  }
</script>
