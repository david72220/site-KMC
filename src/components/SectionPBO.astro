---
// Section PBO — Boîte de terminaison et Formation 2
// Formation 2 : Monteur de lignes fibre optique
---

<section class="pbo-section relative w-full bg-kmc-night overflow-hidden">
  <div class="pbo-container relative min-h-screen flex items-center justify-center px-6 py-20">
    <!-- Background Glow doré -->
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-1/2 right-0 -translate-y-1/2 w-[500px] h-[500px] bg-kmc-gold/10 rounded-full blur-[120px]"></div>
    </div>

    <div class="relative z-10 max-w-6xl w-full grid lg:grid-cols-2 gap-12 items-center">
      <!-- Visual: PBO Box + Équipement -->
      <div class="pbo-visual relative h-[500px] flex items-center justify-center">
        <svg viewBox="0 0 400 500" class="w-full h-full max-w-[340px]" aria-hidden="true">
          <!-- Mur -->
          <rect x="20" y="50" width="360" height="400" rx="2" fill="#1a2332" stroke="#334155" stroke-width="1"/>
          
          <!-- Fibre entrant par la gauche -->
          <path class="fiber-in" d="M -20 200 Q 60 200 80 200" fill="none" stroke="#f59e0b" stroke-width="4" stroke-linecap="round"/>
          
          <!-- Boîte PBO -->
          <rect x="80" y="120" width="200" height="160" rx="6" fill="#0f172a" stroke="#f59e0b" stroke-width="2"/>
          <rect x="90" y="130" width="180" height="140" rx="4" fill="#1e293b" stroke="#334155" stroke-width="1"/>
          
          <!-- Connecteurs dans la PBO -->
          <circle cx="120" cy="170" r="8" fill="#f59e0b" opacity="0.8"/>
          <circle cx="150" cy="170" r="8" fill="#f59e0b" opacity="0.6"/>
          <circle cx="180" cy="170" r="8" fill="#f59e0b" opacity="0.4"/>
          
          <!-- Sortie vers le routeur -->
          <path class="fiber-out" d="M 280 200 L 340 200 L 340 320" fill="none" stroke="#f59e0b" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
          
          <!-- Routeur/Modem -->
          <rect x="300" y="320" width="80" height="50" rx="4" fill="#1e293b" stroke="#f59e0b" stroke-width="2"/>
          <rect x="310" y="330" width="60" height="30" rx="2" fill="#0f172a"/>
          <circle cx="320" cy="345" r="3" fill="#f59e0b" class="led-pulse"/>
          <circle cx="330" cy="345" r="3" fill="#22c55e" class="led-pulse"/>
          <circle cx="340" cy="345" r="3" fill="#3b82f6" class="led-pulse"/>
          
          <!-- Ondes WiFi -->
          <g class="wifi-waves" opacity="0.6">
            <path d="M 340 290 Q 360 270 380 290" fill="none" stroke="#f59e0b" stroke-width="2" stroke-linecap="round"/>
            <path d="M 340 285 Q 365 260 390 285" fill="none" stroke="#f59e0b" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M 340 280 Q 370 250 400 280" fill="none" stroke="#f59e0b" stroke-width="1" stroke-linecap="round"/>
          </g>
          
          <!-- Label PBO -->
          <rect x="130" y="250" width="100" height="24" rx="4" fill="#f59e0b/20" stroke="#f59e0b" stroke-width="1"/>
          <text x="180" y="267" text-anchor="middle" fill="#f59e0b" font-size="12" font-family="Space Grotesk" font-weight="bold">PBO</text>
          
          <!-- Glow -->
          <defs>
            <filter id="pbo-glow">
              <feGaussianBlur stdDeviation="4" result="blur"/>
              <feMerge>
                <feMergeNode in="blur"/>
                <feMergeNode in="SourceGraphic"/>
              </feMerge>
            </filter>
          </defs>
        </svg>
        
        <!-- Label doré -->
        <div class="absolute top-4 left-1/2 -translate-x-1/2 bg-kmc-gold/20 backdrop-blur-sm px-4 py-2 rounded-full border border-kmc-gold/40">
          <span class="text-kmc-gold font-display font-bold text-sm tracking-wider">PBO</span>
        </div>
      </div>

      <!-- Content -->
      <div class="content text-center lg:text-left">
        <span class="inline-block text-kmc-gold font-mono text-sm tracking-widest uppercase mb-4">Étape 5</span>
        <h2 class="font-display text-4xl md:text-5xl font-bold text-kmc-white mb-6 leading-tight">
          Le <span class="text-kmc-gold">PBO</span><br>
          <span class="text-2xl md:text-3xl font-normal text-kmc-light">Point de branchement optique</span>
        </h2>
        <p class="text-lg text-kmc-light leading-relaxed mb-8 max-w-lg mx-auto lg:mx-0">
          La fibre entre dans le logement et se termine dans la PBO. C'est le point 
          final où la connexion optique devient réseau domestique, prête à alimenter 
          tous les appareils du foyer.
        </p>

        <!-- Stats -->
        <div class="stats grid grid-cols-3 gap-6 mb-10 max-w-md mx-auto lg:mx-0">
          <div class="stat-item text-center lg:text-left">
            <div class="font-display text-3xl font-bold text-kmc-gold">1</div>
            <div class="text-sm text-kmc-light">fibre</div>
          </div>
          <div class="stat-item text-center lg:text-left">
            <div class="font-display text-3xl font-bold text-kmc-gold">1 Gbps</div>
            <div class="text-sm text-kmc-light">débit</div>
          </div>
          <div class="stat-item text-center lg:text-left">
            <div class="font-display text-3xl font-bold text-kmc-gold">0</div>
            <div class="text-sm text-kmc-light">perte</div>
          </div>
        </div>

        <!-- Formation 2 CTA Card -->
        <div class="formation-card bg-gradient-to-br from-kmc-gold/20 to-transparent backdrop-blur-sm border border-kmc-gold/30 rounded-2xl p-6 max-w-md mx-auto lg:mx-0 hover:border-kmc-gold/60 transition-colors duration-300">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-full bg-kmc-gold/20 flex items-center justify-center">
              <svg class="w-5 h-5 text-kmc-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <span class="text-kmc-gold font-mono text-xs tracking-wider uppercase">Formation</span>
          </div>
          <h3 class="font-display text-xl font-bold text-kmc-white mb-2">Monteur de lignes fibre optique</h3>
          <p class="text-sm text-kmc-light mb-4">Maîtrisez la pose, l'épissure et la certification des lignes fibre jusqu'au domicile.</p>
          <a href="/formations-fibre-optique/" class="inline-flex items-center gap-2 text-kmc-gold font-semibold hover:gap-3 transition-all">
            Découvrir la formation
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  
  gsap.registerPlugin(ScrollTrigger);
  
  const isMobile = window.matchMedia('(pointer: coarse)').matches;
  const section = document.querySelector('.pbo-section');
  if (section) {
    const container = section.querySelector('.pbo-container');
    const content = section.querySelectorAll('.content > *');
    const fiberIn = section.querySelector('.fiber-in');
    const fiberOut = section.querySelector('.fiber-out');
    const ledPulse = section.querySelectorAll('.led-pulse');
    const wifiWaves = section.querySelector('.wifi-waves');
    const stats = section.querySelectorAll('.stat-item');
    const formationCard = section.querySelector('.formation-card');
    
    if (!isMobile && container) {
      ScrollTrigger.create({
        trigger: container,
        start: 'top top',
        end: '+=130%',
        pin: true,
        scrub: 1,
      });
    }
    
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: 'top 80%',
        end: 'center center',
        scrub: 1,
      }
    });
    
    tl.from(content, {
      y: 60,
      opacity: 0,
      duration: 1,
      stagger: 0.1,
      ease: 'power2.out'
    })
    .from([fiberIn, fiberOut], {
      strokeDasharray: 300,
      strokeDashoffset: 300,
      duration: 1.5,
      stagger: 0.3,
      ease: 'power2.out'
    }, '-=0.8')
    .from(ledPulse, {
      scale: 0,
      opacity: 0,
      duration: 0.4,
      stagger: 0.1,
      ease: 'back.out(1.7)'
    }, '-=1')
    .from(wifiWaves, {
      opacity: 0,
      scale: 0.8,
      duration: 1,
      ease: 'power2.out'
    }, '-=0.5')
    .from(stats, {
      y: 30,
      opacity: 0,
      duration: 0.8,
      stagger: 0.1,
      ease: 'power2.out'
    }, '-=0.5')
    .from(formationCard, {
      y: 40,
      opacity: 0,
      duration: 1,
      ease: 'power2.out'
    }, '-=0.3');
    
    // LED pulse animation en boucle
    gsap.to(ledPulse, {
      opacity: 0.3,
      duration: 1,
      stagger: 0.2,
      repeat: -1,
      yoyo: true,
      ease: 'sine.inOut'
    });
    
    // WiFi waves animation
    if (wifiWaves) {
      gsap.to(wifiWaves.querySelectorAll('path'), {
        opacity: 0.2,
        duration: 1.5,
        stagger: 0.3,
        repeat: -1,
        yoyo: true,
        ease: 'sine.inOut'
      });
    }
  }
</script>